# Prospect data source
HUNTER_API_KEY=

# LLM for personalized copy.
# Optional: leave ANTHROPIC_API_KEY blank and use the "Claude Code CLI" draft
# mode instead, which uses your local `claude` login (no API key).
ANTHROPIC_API_KEY=
# Optional model override for the Claude Code CLI draft mode:
# COLDEMAILS_CLAUDE_CLI_MODEL=claude-haiku-4-5-20251001

# Gmail OAuth: path to the downloaded OAuth client secret, and where to cache the token
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Sender identity used in outgoing emails
SENDER_NAME=
SENDER_EMAIL=

# Local state
COLDEMAILS_DB=coldemails.db
